{
    "id": "cemeteries",
    "endpoint": {
        "url": "https://ldf.fi/warsampo-qlever/sparql",
        "useAuth": false,
        "prefixesFile": "SparqlQueriesPrefixes.js"
    },
    "sparqlQueriesFile": "SparqlQueriesCemeteries.js",
    "baseURI": "http://ldf.fi/warsa/places",
    "URITemplate": "<BASE_URI>/cemeteries/<LOCAL_ID>",
    "facetClass": "warsa:Cemetery",
    "frontPageImage": "main_page/cemeteries.jpg",
    "searchMode": "faceted-search",
    "enableDynamicLanguageChange": true,
    "defaultActiveFacets": [
        "prefLabel"
    ],
    "defaultTab": "table",
    "defaultInstancePageTab": "table",
    "maps": {
        "cemeteriesMap": {
            "center": [
                65.184809,
                27.314050
            ],
            "zoom": 4
        },
        "cemeteryLocation": {
            "center": [
                65.184809,
                27.314050
            ],
            "zoom": 4
        }
    },
    "resultClasses": {
        "cemeteries": {
            "paginatedResultsConfig": {
                "tabID": 0,
                "component": "ResultTable",
                "tabPath": "table",
                "tabIcon": "CalendarViewDay",
                "propertiesQueryBlock": "cemeteryProperties",
                "paginatedResultsAlwaysExpandRows": false,
                "paginatedResultsRowContentMaxHeight": 190,
                "pagesize": 10,
                "sortBy": null,
                "sortDirection": null
            },
            "instanceConfig": {
                "propertiesQueryBlock": "cemeteryPropertiesInstancePage",
                "instancePageResultClasses": {
                    "instancePageTable": {
                        "tabID": 0,
                        "component": "InstancePageTable",
                        "tabPath": "table",
                        "tabIcon": "CalendarViewDay"
                    },
                    "cemeteryLocation": {
                        "tabID": 1,
                        "pageType": "instancePage",
                        "component": "LeafletMap",
                        "tabPath": "map",
                        "tabIcon": "AddLocation",
                        "sparqlQuery": "cemeteryMapQuery",
                        "facetClass": "cemeteries",
                        "filterTarget": "id",
                        "resultMapper": "mapInstancePagePlaces",
                        "instanceConfig": {
                            "createPopUpContent": "createConfigurablePopUpContent",
                            "popUpElements": [
                                { 
                                    "htmlElement": "h3",
                                    "arrayParentElement": null,
                                    "type": "object",
                                    "source": "sparql",
                                    "variableName": "prefLabel",
                                    "isArray": false,
                                    "makeLink": false,
                                    "externalLink": false
                                }
                            ]
                        },
                        "showExternalLayers": false,
                        "showInstanceCountInClusters": false
                    },
                    "instancePageCasualties": {
                        "tabID": 2,
                        "component": "InstancePageTable",
                        "tabPath": "buried_casualties",
                        "tabIcon": "FormatListBulleted",
                        "fetchResultsWhenMounted": true,
                        "sparqlQuery": "casualtiesInstancePageQuery",
                        "properties": [
                            {
                                "id": "buriedCasualties",
                                "valueType": "object",
                                "makeLink": true,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 250,
                                "maxHeight": 700,
                                "onlyOnInstancePage": true,
                                "expandedOnInstancePage": true
                            }
                        ]
                    },
                    "perishingCategoryPieChart": {
                        "tabID": 3,
                        "component": "ApexCharts",
                        "doNotRenderOnMount": true,
                        "tabPath": "perishing_category",
                        "tabIcon": "PieChart",
                        "pageType": "instancePage",
                        "sparqlQuery": "deathsByPerishingCategoryQuery",
                        "resultMapper": "mapPieChart",
                        "sliceVisibilityThreshold": null,
                        "dropdownForResultClasses": false,
                        "dropdownForChartTypes": true,
                        "chartTypes": [
                            {
                                "id": "pie",
                                "createChartData": "createApexPieChartData"
                            },
                            {
                                "id": "bar",
                                "createChartData": "createApexBarChartData"
                            }
                        ]
                    },
                    "rankPieChart": {
                        "tabID": 4,
                        "component": "ApexCharts",
                        "doNotRenderOnMount": true,
                        "tabPath": "rank",
                        "tabIcon": "PieChart",
                        "pageType": "instancePage",
                        "sparqlQuery": "deathsByRankQuery",
                        "resultMapper": "mapPieChart",
                        "sliceVisibilityThreshold": null,
                        "dropdownForResultClasses": false,
                        "dropdownForChartTypes": true,
                        "chartTypes": [
                            {
                                "id": "pie",
                                "createChartData": "createApexPieChartData"
                            },
                            {
                                "id": "bar",
                                "createChartData": "createApexBarChartData"
                            }
                        ]
                    },
                    "unitPieChart": {
                        "tabID": 5,
                        "component": "ApexCharts",
                        "doNotRenderOnMount": true,
                        "tabPath": "unit",
                        "tabIcon": "PieChart",
                        "pageType": "instancePage",
                        "sparqlQuery": "deathsByUnitQuery",
                        "resultMapper": "mapPieChart",
                        "sliceVisibilityThreshold": null,
                        "dropdownForResultClasses": false,
                        "dropdownForChartTypes": true,
                        "chartTypes": [
                            {
                                "id": "pie",
                                "createChartData": "createApexPieChartData"
                            },
                            {
                                "id": "bar",
                                "createChartData": "createApexBarChartData"
                            }
                        ]
                    },
                    "ageBarChart": {
                        "tabID": 6,
                        "component": "ApexCharts",
                        "doNotRenderOnMount": true,
                        "tabPath": "age",
                        "tabIcon": "PieChart",
                        "pageType": "instancePage",
                        "sparqlQuery": "deathsByAgeQuery",
                        "resultMapper": "mapIntBarChart",
                        "sliceVisibilityThreshold": -1,
                        "dropdownForResultClasses": false,
                        "dropdownForChartTypes": false,
                        "fillEmptyValues": true,
                        "seriesTitle": "Lukumäärä / Count",
                        "chartTypes": [
                            {
                                "id": "bar",
                                "createChartData": "createApexBarChartData"
                            }
                        ],
                        "resultMapperConfig": {
                            "fillEmptyValues": true
                        }
                    }
                }
            }
        },
        "cemeteriesMap": {
            "tabID": 3,
            "component": "LeafletMap",
            "tabPath": "map",
            "tabIcon": "AddLocation",
            "sparqlQuery": "cemeteryPlacesQuery",
            "facetClass": "cemeteries",
            "filterTarget": "cemetery",
            "resultMapper": "mapPlaces",
            "showExternalLayers": true,
            "instanceConfig": {
                "propertiesQueryBlock": "placePropertiesInfoWindow",
                "relatedInstances": "peopleBuriedAt",
                "filterTarget": "id",
                "createPopUpContent": "createConfigurablePopUpContent",
                "popUpElements": [
                    { 
                        "htmlElement": "img",
                        "arrayParentElement": null,
                        "type": "object",
                        "source": "sparql",
                        "variableName": "image",
                        "isArray": false,
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "h3",
                        "arrayParentElement": null,
                        "type": "object",
                        "source": "sparql",
                        "variableName": "prefLabel",
                        "isArray": false,
                        "makeLink": true,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "span",
                        "arrayParentElement": null,
                        "type": "string",
                        "source": "intl",
                        "variableName": "leafletMap.resultClasses.cemeteriesMap.numberOfGraves",
                        "isArray": false,
                        "orderBy": null,
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "span",
                        "arrayParentElement": null,
                        "type": "string",
                        "source": "sparql",
                        "variableName": "numberOfGraves",
                        "isArray": false,
                        "includeUndefined": true,
                        "undefinedReplacementIntl": "leafletMap.resultClasses.cemeteriesMap.unknown",
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "p",
                        "arrayParentElement": null,
                        "type": "string",
                        "source": "intl",
                        "variableName": "leafletMap.resultClasses.cemeteriesMap.peopleBuriedAt",
                        "isArray": false,
                        "orderBy": null,
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "li",
                        "arrayParentElement": "ul",
                        "type": "object",
                        "source": "sparql",
                        "variableName": "related",
                        "isArray": true,
                        "orderBy": "prefLabel",
                        "includeUndefined": true,
                        "makeLink": true,
                        "externalLink": false
                    }
                ]
            }
        }
    },
    "properties": [
        {
            "id": "image",
            "valueType": "image",
            "previewImageHeight": 150,
            "makeLink": true,
            "externalLink": true,
            "sortValues": true,
            "numberedList": false,
            "hideHeader": true
        },
        {
            "id": "prefLabel",
            "valueType": "object",
            "makeLink": true,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "minWidth": 200
        },
        {
            "id": "altLabel",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "formerMunicipality",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "currentMunicipality",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "numberOfGraves",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "architect",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "address",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "lat",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "long",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "dateOfFoundation",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "cameraClub",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "memorial",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "memorialSculptor",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "memorialUnveilingDate",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "source",
            "valueType": "object",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "uri",
            "valueType": "object",
            "makeLink": true,
            "externalLink": true,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        }
    ],
    "facets": {
        "prefLabel": {
            "containerClass": "one",
            "facetType": "text",
            "filterType": "textFilter",
            "sortByPredicate": "skos:prefLabel",
            "textQueryProperty": "skos:prefLabel",
            "textQueryType": "regex"
        },
        "formerMunicipality": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:former_municipality",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:former_municipality",
            "sortDirection": "desc"
        },
        "currentMunicipality": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:current_municipality",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:current_municipality",
            "sortDirection": "desc"
        },
        "numberOfGraves": {
            "containerClass": "five",
            "facetType": "integer",
            "filterType": "integerFilterRange",
            "predicate": "cemeteries:number_of_graves",
            "sortByPredicate": "cemeteries:number_of_graves"
        },
        "architect": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:architect",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:architect",
            "sortDirection": "desc"
        },
        "buriedCasualties": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "^warsa:buried_in",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "^warsa:buried_in/skos:prefLabel",
            "sortDirection": "desc"
        }
    }
}