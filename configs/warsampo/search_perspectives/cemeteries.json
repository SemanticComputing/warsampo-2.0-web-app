{
    "id": "cemeteries",
    "endpoint": {
        "url": "https://ldf.fi/warsa/sparql",
        "useAuth": false,
        "prefixesFile": "SparqlQueriesPrefixes.js"
    },
    "sparqlQueriesFile": "SparqlQueriesCemeteries.js",
    "baseURI": "http://ldf.fi/warsa/places",
    "URITemplate": "<BASE_URI>/cemeteries/<LOCAL_ID>",
    "facetClass": "warsa:Cemetery",
    "frontPageImage": "main_page/manuscripts-452x262.jpg",
    "searchMode": "faceted-search",
    "enableDynamicLanguageChange": true,
    "defaultActiveFacets": [
        "prefLabel"
    ],
    "defaultTab": "table",
    "defaultInstancePageTab": "table",
    "resultClasses": {
        "cemeteries": {
            "paginatedResultsConfig": {
                "tabID": 0,
                "component": "ResultTable",
                "tabPath": "table",
                "tabIcon": "CalendarViewDay",
                "propertiesQueryBlock": "cemeteryProperties",
                "paginatedResultsAlwaysExpandRows": false,
                "paginatedResultsRowContentMaxHeight": 190,
                "pagesize": 10,
                "sortBy": null,
                "sortDirection": null
            },
            "instanceConfig": {
                "propertiesQueryBlock": "cemeteryProperties",
                "instancePageResultClasses": {
                    "instancePageTable": {
                        "tabID": 0,
                        "component": "InstancePageTable",
                        "tabPath": "table",
                        "tabIcon": "CalendarViewDay"
                    }
                }
            }
        }
    },
    "properties": [
        {
            "id": "image",
            "valueType": "image",
            "previewImageHeight": 150,
            "makeLink": true,
            "externalLink": true,
            "sortValues": true,
            "numberedList": false,
            "hideHeader": true
        },
        {
            "id": "uri",
            "valueType": "object",
            "makeLink": true,
            "externalLink": true,
            "sortValues": true,
            "numberedList": false,
            "onlyOnInstancePage": true
        },
        {
            "id": "prefLabel",
            "valueType": "object",
            "makeLink": true,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false,
            "minWidth": 200
        },
        {
            "id": "altLabel",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "formerMunicipality",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "currentMunicipality",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "numberOfGraves",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        },
        {
            "id": "architect",
            "valueType": "string",
            "makeLink": false,
            "externalLink": false,
            "sortValues": true,
            "numberedList": false
        }
    ],
    "facets": {
        "prefLabel": {
            "containerClass": "one",
            "facetType": "text",
            "filterType": "textFilter",
            "sortByPredicate": "skos:prefLabel",
            "textQueryProperty": "skos:prefLabel"
        },
        "formerMunicipality": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:former_municipality",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:former_municipality",
            "sortDirection": "desc"
        },
        "currentMunicipality": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:current_municipality",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:current_municipality",
            "sortDirection": "desc"
        },
        "numberOfGraves": {
            "containerClass": "five",
            "facetType": "integer",
            "filterType": "integerFilterRange",
            "predicate": "cemeteries:number_of_graves",
            "sortByPredicate": "cemeteries:number_of_graves"
        },
        "architect": {
            "containerClass": "ten",
            "facetType": "list",
            "literal": true,
            "filterType": "uriFilter",
            "predicate": "cemeteries:architect",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "cemeteries:architect",
            "sortDirection": "desc"
        }
    }
}