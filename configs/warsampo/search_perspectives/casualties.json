        "article": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "crm-org:P70_documents/^articles:mentionsPerson",
            "labelPattern": "OPTIONAL { ?id dce:title ?title_ ; articles:issue/skos:prefLabel ?issue_ . BIND(CONCAT(STR(?title_), \" (Kansa Taisteli \", STR(?issue_), \")\") AS ?prefLabel_) } BIND(COALESCE(STR(?prefLabel_), STR(?id)) AS ?prefLabel)",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "crm-org:P70_documents/^articles:mentionsPerson/dce:title",
