            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "warsa:buried_in/skos:prefLabel",
            "sortDirection": "desc"
        },
        "municipalityOfDomicile": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "casualties:municipality_of_domicile",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "casualties:municipality_of_domicile/skos:prefLabel",
            "sortDirection": "desc"
        },
        "municipalityOfDeath": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "casualties:municipality_of_death",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "casualties:municipality_of_death/skos:prefLabel",
            "sortDirection": "desc"
        },
        "deathTimeTimespan": {
            "containerClass": "four",
            "facetType": "timespan",
            "filterType": "dateFilter",
            "predicate": "^crm:P70i_is_documented_in/^crm:P100_was_death_of/crm:P4_has_time-span",
            "sortByAscPredicate": "^crm:P70i_is_documented_in/^crm:P100_was_death_of/crm:P4_has_time-span/crm:P82a_begin_of_the_begin",
            "sortByDescPredicate": "^crm:P70i_is_documented_in/^crm:P100_was_death_of/crm:P4_has_time-span/crm:P82b_end_of_the_end",
            "startProperty": "crm:P82a_begin_of_the_begin",
            "endProperty": "crm:P82b_end_of_the_end",
            "min": null,
            "max": null
        },
        "unit": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "casualties:unit",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "casualties:unit/skos:prefLabel",
            "sortDirection": "desc"
        }
    }
