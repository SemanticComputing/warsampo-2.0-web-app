{
    "id": "casualties",
    "endpoint": {
        "url": "https://ldf.fi/warsampo-qlever/sparql",
        "useAuth": false,
        "prefixesFile": "SparqlQueriesPrefixes.js"
    },
    "sparqlQueriesFile": "SparqlQueriesCasualties.js",
    "baseURI": "http://ldf.fi/warsa",
    "URITemplate": "<BASE_URI>/casualties/<LOCAL_ID>",
    "facetClass": "warsa:DeathRecord",
    "frontPageImage": "main_page/casualties.jpg",
    "searchMode": "faceted-search",
    "enableDynamicLanguageChange": true,
    "defaultActiveFacets": [
        "prefLabel"
    ],
    "defaultTab": "table",
    "defaultInstancePageTab": "table",
    "maps": {
        "deathsByMunicipalityOfDomicile": {
            "center": [
                65.184809,
                27.314050
            ],
            "zoom": 4
        },
        "deathPlacesMap": {
            "center": [
                65.184809,
                27.314050
            ],
            "zoom": 4
        },
        "casualtyMigrations": {
            "center": [
                65.184809,
                27.314050
            ],
            "zoom": 4
        }
    },
    "resultClasses": {
        "casualties": {
            "paginatedResultsConfig": {
                "tabID": 0,
                "component": "ResultTable",
                "tabPath": "table",
                "tabIcon": "CalendarViewDay",
                "propertiesQueryBlock": "casualtyProperties",
                "paginatedResultsAlwaysExpandRows": false,
                "paginatedResultsRowContentMaxHeight": 190,
                "pagesize": 10,
                "sortBy": null,
                "sortDirection": null
            },
            "instanceConfig": {
                "propertiesQueryBlock": "casualtyPropertiesInstancePage",
                "instancePageResultClasses": {
                    "instancePageTable": {
                        "tabID": 0,
                        "component": "InstancePageTable",
                        "tabPath": "table",
                        "tabIcon": "CalendarViewDay"
                    }
                }
            }
        },
        "casualtiesPieChart": {
            "tabID": 1,
            "component": "ApexCharts",
            "doNotRenderOnMount": true,
            "tabPath": "pie_chart",
            "tabIcon": "PieChart",
            "facetClass": "casualties",
            "dropdownForResultClasses": true,
            "defaultResultClass": "deathsByPerishingCategory",
            "resultClasses": {
                "deathsByPerishingCategory": {
                    "sparqlQuery": "deathsByPerishingCategoryQuery",
                    "filterTarget": "record",
                    "resultMapper": "mapPieChart",
                    "sliceVisibilityThreshold": null,
                    "dropdownForChartTypes": "true",
                    "chartTypes": [
                        {
                            "id": "pie",
                            "createChartData": "createApexPieChartData"
                        },
                        {
                            "id": "bar",
                            "createChartData": "createApexBarChartData"
                        }
                    ]
                },
                "deathsByMaritalStatus": {
                    "sparqlQuery": "deathsByMaritalStatusQuery",
                    "filterTarget": "record",
                    "resultMapper": "mapPieChart",
                    "sliceVisibilityThreshold": null,
                    "dropdownForChartTypes": "true",
                    "chartTypes": [
                        {
                            "id": "pie",
                            "createChartData": "createApexPieChartData"
                        },
                        {
                            "id": "bar",
                            "createChartData": "createApexBarChartData"
                        }
                    ]
                },
                "deathsByGender": {
                    "sparqlQuery": "deathsByGenderQuery",
                    "filterTarget": "record",
                    "resultMapper": "mapPieChart",
                    "sliceVisibilityThreshold": null,
                    "dropdownForChartTypes": "true",
                    "chartTypes": [
                        {
                            "id": "pie",
                            "createChartData": "createApexPieChartData"
                        },
                        {
                            "id": "bar",
                            "createChartData": "createApexBarChartData"
                        }
                    ]
                },
                "deathsByMotherTongue": {
                    "sparqlQuery": "deathsByMotherTongueQuery",
                    "filterTarget": "record",
                    "resultMapper": "mapPieChart",
                    "sliceVisibilityThreshold": null,
                    "dropdownForChartTypes": "true",
                    "chartTypes": [
                        {
                            "id": "pie",
                            "createChartData": "createApexPieChartData"
                        },
                        {
                            "id": "bar",
                            "createChartData": "createApexBarChartData"
                        }
                    ]
                },
                "deathsByNumberOfChildren": {
                    "sparqlQuery": "deathsByNumberOfChildrenQuery",
                    "filterTarget": "record",
                    "resultMapper": "mapPieChart",
                    "sliceVisibilityThreshold": null,
                    "dropdownForChartTypes": "true",
                    "chartTypes": [
                        {
                            "id": "pie",
                            "createChartData": "createApexPieChartData"
                        },
                        {
                            "id": "bar",
                            "createChartData": "createApexBarChartData"
                        }
                    ]
                }
            }
        },
        "deathsByMunicipalityOfDomicile": {
            "tabID": 2,
            "component": "Deck",
            "tabPath": "choropleth_map",
            "tabIcon": "LocationOn",
            "sparqlQuery": "deathsByMunicipalityOfDomicileQuery",
            "facetClass": "casualties",
            "filterTarget": "record",
            "layerType": "polygonLayer",
            "postprocess": {
                "func": "toPolygonLayerFormat",
                "config": {
                    "ckmeansClustering": true
                }
            }
        },
        "deathPlacesMap": {
            "tabID": 3,
            "component": "LeafletMap",
            "tabPath": "death_places",
            "tabIcon": "AddLocation",
            "sparqlQuery": "deathPlacesQuery",
            "facetClass": "casualties",
            "filterTarget": "record",
            "resultMapper": "mapPlaces",
            "showExternalLayers": true,
            "instanceConfig": {
                "propertiesQueryBlock": "placePropertiesInfoWindow",
                "relatedInstances": "deathsHappenedAt",
                "filterTarget": "related__id",
                "createPopUpContent": "createConfigurablePopUpContent",
                "popUpElements": [
                    { 
                        "htmlElement": "h3",
                        "arrayParentElement": null,
                        "type": "object",
                        "source": "sparql",
                        "variableName": "prefLabel",
                        "isArray": false,
                        "orderBy": null,
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "p",
                        "arrayParentElement": null,
                        "type": "string",
                        "source": "intl",
                        "variableName": "leafletMap.resultClasses.deathPlacesMap.deathsHappenedAt",
                        "isArray": false,
                        "orderBy": null,
                        "makeLink": false,
                        "externalLink": false
                    },
                    { 
                        "htmlElement": "li",
                        "arrayParentElement": "ul",
                        "type": "object",
                        "source": "sparql",
                        "variableName": "related",
                        "isArray": true,
                        "orderBy": "prefLabel",
                        "includeUndefined": true,
                        "makeLink": true,
                        "externalLink": false
                    }
                ]
            }
        },
        "casualtyMigrations": {
            "tabID": 4,
            "component": "Deck",
            "tabPath": "migrations",
            "tabIcon": "Redo",
            "sparqlQuery": "migrationsQuery",
            "facetClass": "casualties",
            "filterTarget": "record",
            "resultMapper": "makeObjectList",
            "layerType": "arcLayer",
            "arcWidthVariable": "instanceCountScaled",
            "instanceVariable": "record",
            "showTooltips": true,
            "postprocess": {
                "func": "linearScale",
                "config": {
                    "variable": "instanceCount",
                    "minAllowed": 1,
                    "maxAllowed": 30
                }
            }
        },
        "casualtyMigrationsDialog": {
            "sparqlQuery": "migrationsDialogQuery",
            "filterTarget": "id",
            "resultMapper": "makeObjectList"
        },
        "deathPlacesAnimation": {
            "tabID": 5,
            "component": "TemporalMap",
            "tabPath": "casualties_animation",
            "tabIcon": "Animation",
            "sparqlQuery": "deathPlacesAnimationQuery",
            "facetClass": "casualties",
            "filterTarget": "record",
            "config": {
                "radiusScale": 50,
                "radiusMinPixels": 3,
                "radiusMaxPixels": 100,
                "radiusVariable": "instanceCount",
                "radiusVariableMultiplier": 2,
                "sliderDuration": {
                    "halfSpeed": 300,
                    "normalSpeed": 150,
                    "doubleSpeed": 75
                }
            }
        }
    },
