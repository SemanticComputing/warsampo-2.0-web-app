        "prefLabel": {
            "containerClass": "one",
            "facetType": "text",
            "filterType": "textFilter",
            "sortByPredicate": "skos:prefLabel",
            "textQueryProperty": "skos:prefLabel",
            "textQueryType": "regex"
        },
        "rank": {
            "containerClass": "ten",
            "facetType": "list",
            "facetLabelFilter": "FILTER(LANG(?prefLabel_) = '<LANG>')",
            "filterType": "uriFilter",
            "predicate": "casualties:rank",
            "searchField": true,
            "sortButton": true,
