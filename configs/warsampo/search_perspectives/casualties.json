            "sortByPredicate": "warsa:mother_tongue/skos:prefLabel",
            "sortDirection": "desc"
        },
        "citizenship": {
            "containerClass": "ten",
            "facetType": "list",
            "facetLabelFilter": "FILTER(LANG(?prefLabel_) = '<LANG>')",
            "filterType": "uriFilter",
            "predicate": "warsa:citizenship",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "warsa:citizenship/skos:prefLabel",
            "sortDirection": "desc"
        },
        "nationality": {
            "containerClass": "ten",
            "facetType": "list",
            "facetLabelFilter": "FILTER(LANG(?prefLabel_) = '<LANG>')",
            "filterType": "uriFilter",
            "predicate": "warsa:nationality",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "warsa:nationality/skos:prefLabel",
            "sortDirection": "desc"
        },
        "maritalStatus": {
            "containerClass": "ten",
            "facetType": "list",
            "facetLabelFilter": "FILTER(LANG(?prefLabel_) = '<LANG>')",
            "filterType": "uriFilter",
            "predicate": "warsa:marital_status",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "warsa:marital_status/skos:prefLabel",
            "sortDirection": "desc"
        },
        "perishingCategory": {
            "containerClass": "ten",
            "facetType": "list",
            "facetLabelFilter": "FILTER(LANG(?prefLabel_) = '<LANG>')",
            "filterType": "uriFilter",
            "predicate": "casualties:perishing_category",
            "searchField": true,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "casualties:perishing_category/skos:prefLabel",
